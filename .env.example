# ============================================================
#  Data Copilot — Environment Variables
# ============================================================
#
# Copy this file to ``.env`` (already in .gitignore) and fill in
# the three keys marked REQUIRED below. Everything else has a
# sensible default that works for local development.
#
# Quickest way to get started:
#
#     ./scripts/make-env.sh
#
# It copies this file, prompts for the three required keys, and
# leaves everything else alone.
#
# ============================================================


# -------------------- REQUIRED --------------------------------

# 1. DeepSeek — chat LLM. Register at https://platform.deepseek.com
#    (5 min, phone number, ~$1 minimum top-up). Used for classify /
#    generate_sql / summarize / compaction.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 2. SiliconFlow — embeddings (BGE-M3). Register at
#    https://cloud.siliconflow.cn/ (5 min, phone number; new accounts
#    get free credits and BGE-M3 is on the free tier).
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 3. (Optional but recommended) LangSmith — request tracing.
#    Register at https://smith.langchain.com — free tier covers this
#    project comfortably. Leave the placeholder if you don't want it,
#    LANGSMITH_TRACING below will silently no-op.
LANGSMITH_API_KEY=your_langsmith_api_key_here


# -------------------- LLM provider settings -------------------
# These three together let you swap LLM providers via env var. Any
# OpenAI-compatible endpoint (OpenAI, Together, OpenRouter, …) works.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat


# -------------------- Embedding provider ----------------------
# Same swap-by-env-var story as LLM; defaults work as-is.
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# How many tables retrieve_schema returns before FK expansion.
# 4 is enough for Northwind; raise for wider schemas.
SCHEMA_TOP_K=4


# -------------------- LangSmith fine-tuning -------------------
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=data-copilot-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# -------------------- Database (PostgreSQL + pgvector) ---------
# When using ``docker compose up``, the api / web containers auto-
# point at the postgres service via the network. These vars only
# matter for ``./scripts/dev.sh ask`` from the host.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot_dev_pwd
POSTGRES_DB=northwind
DATABASE_URL=postgresql://copilot:copilot_dev_pwd@localhost:5432/northwind


# -------------------- Caching (week 9 + 11) -------------------
# Leave REDIS_URL empty for the default in-memory cache (works fine
# on a single replica). Set it (e.g. ``rediss://...``) to share the
# embedding cache across multiple Fly.io machines via Upstash.
REDIS_URL=


# -------------------- HITL risk gate (week 7) -----------------
# Postgres planner cost above which the agent pauses for human
# approval. ``0`` disables the gate entirely.
RISK_EXPLAIN_COST_THRESHOLD=1000.0


# -------------------- Conversation memory (week 5) ------------
# When dialogue tokens cross this, older turns get summarised into
# one synthetic entry. 4000 is a comfortable buffer in DeepSeek's
# 64K context.
COMPACTION_THRESHOLD_TOKENS=4000
COMPACTION_KEEP_LAST_N=6


# -------------------- API + frontend ports --------------------
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
LOG_LEVEL=INFO
APP_ENV=development


# -------------------- Cross-origin allowed list ---------------
# Comma-separated origins the API will accept. ``docker compose up``
# automatically wires the web container's hostname; only override
# this for production deploys.
CORS_ORIGINS=http://localhost:3000,http://web:3000
