# ============================================================
#  Data Copilot — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ============================================================

# ---------- LLM (DeepSeek, OpenAI-compatible) ----------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- Embeddings (SiliconFlow, OpenAI-compatible) ----------
# Register at https://cloud.siliconflow.cn/ — BGE-M3 is free to call.
# Swap to any OpenAI-compatible provider by changing the URL and model.
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
SCHEMA_TOP_K=4

# ---------- Observability (LangSmith) ----------
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=data-copilot-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---------- Database (PostgreSQL + pgvector) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot_dev_pwd
POSTGRES_DB=northwind
DATABASE_URL=postgresql://copilot:copilot_dev_pwd@localhost:5432/northwind

# ---------- API Server ----------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ---------- App ----------
APP_ENV=development
