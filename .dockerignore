# Repo-wide .dockerignore. Both image builds run from the repo root
# (see deploy script) so this file covers both contexts.

# VCS
.git
.gitignore
.gitattributes

# Python build / cache
**/__pycache__
**/*.pyc
**/*.pyo
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
htmlcov
.tox
.venv
*.egg-info

# Node / Next.js
**/node_modules
apps/web/.next
apps/web/out
apps/web/.turbo
apps/web/coverage

# IDE / OS junk
.DS_Store
.idea
.vscode
*.swp

# Local-only files
.env
.env.*
!.env.example

# Big things the runtime image never needs
data/
# …but the semantic layer YAML is a runtime config the API needs.
# Keeping the rest of ``data/`` excluded (seed SQL, fixtures, big
# eval CSVs) so the image stays slim.
!data/semantic.yml
notebooks/
docs/
docs/eval/*.md
scripts/
*.md
# Required by uv/hatchling: pyproject.toml declares ``readme =
# "README.md"`` and the build backend reads it during ``uv sync``. The
# alternative would be dropping the README from the package
# description, which we don't want to do.
!README.md
!apps/api/README.md
!apps/web/README.md
LICENSE

# Test fixtures are not needed at runtime
apps/api/tests
apps/web/__tests__
